#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run lint-staged for changed files
npx lint-staged

# Run type checking (if TypeScript is present)
if [ -f "tsconfig.json" ]; then
  echo "🔧 Running TypeScript type check..."
  npx tsc --noEmit --pretty
fi

# Run a quick smoke test to ensure app builds
echo "🏗️  Checking if app builds..."
npm run build > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "❌ Build failed. Please fix the build errors before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed!"