#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "📝 Checking commit message format..."

# Read the commit message
commit_message=$(cat "$1")

# Check if commit message follows conventional commits format
# Format: type(scope): description
# Examples: feat: add new feature, fix(api): resolve bug, docs: update README

if echo "$commit_message" | grep -qE "^(feat|fix|docs|style|refactor|test|chore|perf|ci|build)(\(.+\))?!?: .{1,50}"; then
  echo "✅ Commit message format is valid"
else
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Please use the conventional commits format:"
  echo "  type(scope): description"
  echo ""
  echo "Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build"
  echo "Examples:"
  echo "  feat: add user authentication"
  echo "  fix(api): resolve login endpoint bug"
  echo "  docs: update API documentation"
  echo "  test: add unit tests for analytics component"
  echo ""
  exit 1
fi