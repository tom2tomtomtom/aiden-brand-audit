# Frontend Environment Variables Configuration
# Copy this file to .env and fill in your values

# ===========================================
# API Configuration
# ===========================================

# Backend API Base URL
# Development: http://localhost:8000/api
# Production: https://your-domain.com/api
# Ngrok: https://xyz.ngrok-free.app/api
VITE_API_BASE_URL=http://localhost:8000/api

# API Request Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# Maximum retry attempts for failed requests
VITE_MAX_RETRY_ATTEMPTS=3

# ===========================================
# Application Configuration
# ===========================================

# App Environment
# Options: development, staging, production
VITE_APP_ENV=development

# App Version (automatically updated during build)
VITE_APP_VERSION=1.0.0

# App Name (displayed in browser title)
VITE_APP_NAME=AI Brand Audit Tool

# ===========================================
# Feature Flags
# ===========================================

# Enable/disable analytics dashboard
VITE_ENABLE_ANALYTICS=true

# Enable/disable error reporting
VITE_ENABLE_ERROR_REPORTING=true

# Enable/disable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Enable/disable offline mode
VITE_ENABLE_OFFLINE_MODE=false

# ===========================================
# External Services
# ===========================================

# Error tracking service (e.g., Sentry)
VITE_SENTRY_DSN=

# Analytics service (e.g., Google Analytics)
VITE_GA_TRACKING_ID=

# Customer support widget
VITE_INTERCOM_APP_ID=

# ===========================================
# UI/UX Configuration
# ===========================================

# Default theme (light, dark, system)
VITE_DEFAULT_THEME=light

# Enable/disable animations
VITE_ENABLE_ANIMATIONS=true

# Toast notification duration (milliseconds)
VITE_TOAST_DURATION=5000

# ===========================================
# Security Configuration
# ===========================================

# Content Security Policy nonce (generated during build)
VITE_CSP_NONCE=

# Enable/disable development tools in production
VITE_ENABLE_DEV_TOOLS=false

# Rate limiting configuration
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=3600000

# ===========================================
# Performance Configuration
# ===========================================

# Lazy loading threshold (pixels from viewport)
VITE_INTERSECTION_THRESHOLD=100

# Image optimization quality (1-100)
VITE_IMAGE_QUALITY=85

# Maximum file upload size (bytes)
VITE_MAX_FILE_SIZE=16777216

# ===========================================
# Debug Configuration
# ===========================================

# Enable verbose logging in development
VITE_DEBUG_LOGGING=true

# Enable API request/response logging
VITE_DEBUG_API_CALLS=true

# Enable performance measurement
VITE_DEBUG_PERFORMANCE=false