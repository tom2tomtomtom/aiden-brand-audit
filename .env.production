# AI Brand Audit Tool - Production Environment Configuration
# Generated: July 26, 2025

# Application Configuration
FLASK_ENV=production
DEBUG=false
PORT=8000

# Security Configuration
SECRET_KEY=brand-audit-production-secret-key-2025
JWT_SECRET_KEY=brand-audit-jwt-secret-key-2025

# Database Configuration
DATABASE_URL=sqlite:///./instance/app.db

# CORS Configuration
ALLOWED_ORIGINS=https://brandaudit.up.railway.app,https://207d-220-244-77-193.ngrok-free.app

# API Keys - Replace with actual production keys
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
NEWS_API_KEY=${NEWS_API_KEY}
BRANDFETCH_API_KEY=${BRANDFETCH_API_KEY}
OPENCORPORATES_API_KEY=${OPENCORPORATES_API_KEY}

# Performance Configuration
WORKERS=4
THREADS=2
TIMEOUT=120

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# Cache Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=simple

# Rate Limiting
RATE_LIMIT_STORAGE_URL=memory://
RATE_LIMIT_DEFAULT=1000 per hour

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=true